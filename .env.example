# AI-Поддержка PRO v3.5 — переменные окружения
#
# ОБЯЗАТЕЛЬНЫЕ: без одного из LLM-ключей коробка не работает.
# ОПЦИОНАЛЬНЫЕ: нужны только для включения конкретных интеграций.
#
# Как использовать:
#   cp .env.example .env
#   # откройте .env и заполните нужные ключи
#
# Закомментируйте или удалите неиспользуемые строки.

# ═══════════════════════════════════════════════════
# ОБЯЗАТЕЛЬНО — LLM-ключ (выберите один или оба)
# ═══════════════════════════════════════════════════
# Где брать Anthropic: https://console.anthropic.com/ → API Keys
# Где брать OpenAI: https://platform.openai.com/api-keys

ANTHROPIC_API_KEY=""                        # Claude (рекомендуется для русского)
OPENAI_API_KEY=""                           # OpenAI GPT-4o (альтернатива)

# ═══════════════════════════════════════════════════
# Telegram-бот поддержки (опционально)
# ═══════════════════════════════════════════════════
# Где брать бот-токен: @BotFather в Telegram → /newbot
# Где брать chat_id: @userinfobot → переслать боту любое сообщение
# Гайд: docs/onboarding.md раздел "Telegram-бот"

TELEGRAM_BOT_TOKEN=""                       # токен вашего бота поддержки
TELEGRAM_SUPPORT_CHAT_ID=""                 # ID чата/канала куда слать уведомления
TELEGRAM_ESCALATION_CHAT_ID=""              # ID чата для L2/L3 эскалаций

# ═══════════════════════════════════════════════════
# CRM — Bitrix24 (опционально)
# ═══════════════════════════════════════════════════
# Где брать: Bitrix24 → Настройки → Интеграции → Входящий Webhook
# Гайд: docs/onboarding.md раздел "CRM-интеграция"

BITRIX24_WEBHOOK_URL=""                     # URL webhook для создания лидов/тикетов
BITRIX24_API_KEY=""                         # Ключ API (опционально для extended access)

# ═══════════════════════════════════════════════════
# CRM — amoCRM (опционально)
# ═══════════════════════════════════════════════════
# Где брать: amoCRM → Настройки → API → Ключи и webhook
# Выберите ОДНУ CRM: Bitrix24 или amoCRM

AMOCRM_SUBDOMAIN=""                         # ваш поддомен (example.amocrm.ru → example)
AMOCRM_API_KEY=""                           # ключ API или OAuth access_token

# ═══════════════════════════════════════════════════
# Google Sheets — журнал тикетов (опционально)
# ═══════════════════════════════════════════════════
# Для ведения журнала тикетов и отчётов в Google Sheets
# Где брать: https://console.cloud.google.com/ → Service Account → JSON key

GOOGLE_SHEETS_CREDENTIALS_JSON=""           # путь к JSON-ключу сервис-аккаунта
GOOGLE_SHEETS_SPREADSHEET_ID=""             # ID таблицы (из URL)
GOOGLE_SHEETS_TAB_TICKETS="Tickets"         # вкладка с тикетами
GOOGLE_SHEETS_TAB_REPORTS="Reports"         # вкладка с отчётами

# ═══════════════════════════════════════════════════
# Helpdesk — Freshdesk (опционально)
# ═══════════════════════════════════════════════════
# Для двусторонней синхронизации с Freshdesk
# Где брать: Freshdesk → Admin → API

FRESHDESK_API_KEY=""
FRESHDESK_DOMAIN=""                         # ваш поддомен (example.freshdesk.com → example)

# ═══════════════════════════════════════════════════
# Helpdesk — Zendesk (опционально)
# ═══════════════════════════════════════════════════

ZENDESK_API_TOKEN=""
ZENDESK_EMAIL=""
ZENDESK_SUBDOMAIN=""

# ═══════════════════════════════════════════════════
# Уведомления при инцидентах (опционально)
# ═══════════════════════════════════════════════════

SLACK_WEBHOOK_URL=""                        # Slack-хук для P1-инцидентов
EMAIL_SMTP_HOST=""                          # SMTP для email-уведомлений
EMAIL_SMTP_PORT="587"
EMAIL_FROM=""
EMAIL_TO_L2=""                              # email менеджера L2
EMAIL_TO_L3=""                              # email руководителя L3
